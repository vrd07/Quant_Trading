# ============================================
# Gemini AI artifacts (local only)
# ============================================
.gemini/

# ============================================
# graphify knowledge-graph artifacts (regenerable)
# ============================================
graphify-out/

# Per-user runtime risk overrides (written by scripts/runtime_setup.py)
config/runtime_overrides.yaml

# ============================================
# Runtime Data Override Files (written by download_data / re-download scripts)
# ============================================
data/config_override*.json
data/config_override*.json.*

# Runtime volatility-monitor alerts (regenerated continuously, never needed in the repo)
data/volatility_alerts.jsonl

# Strategy Specific Backtest Outputs
*continuation_breakout*.csv
*continuation_breakout*.txt

# Editor / AI Rules
.cursorrules

# ============================================
# Telegram Bot Module (separate service, not part of core bot)
# ============================================
trading_bot/

# ============================================
# Markdown Files — ignore scratch/planning docs, keep key documentation.
# ============================================
*.md
**/*.md

# Keep: all README files (GitHub-facing documentation)
!README.md
!**/README.md

# Keep: Claude / Agents / lean-ctx infrastructure files
!CLAUDE.md
!AGENTS.md
!LEAN-CTX.md
!.claude/**/*.md
!.agents/**/*.md

# Keep: explicit project docs
!RESEARCH_PAPER.md
!config/backtest_grids/README.md
!mt5_bridge/README_SETUP.md

# Keep: committed weekly reports (Saturday automation writes here)
!docs/weekly/
!docs/weekly/*.md

# Keep: strategy review reports
!reports/
!reports/*.md

# ============================================
# Generated Images & Charts (regenerable from scripts)
# ============================================
docs/*.png
docs/*.jpg

# ============================================
# Root-level Scratch / One-off Test Files
# ============================================
test_min_stops.py

# Sentiment engine API keys (real keys — never commit)
config/sentiment.env

# Sentiment engine runtime data (scores + history)
data/sentiment/

# ============================================
# Historical CSV backups (auto-created by the weekly refresh and
# fetch_dukascopy merges; regenerable, never needed in the repo)
# ============================================
data/historical/*.bak_*
data/historical/*.corrupt_backup_*
data/historical/*.stale_backup_*
data/historical/*.tmp
